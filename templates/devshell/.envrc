# direnv loads this when you `cd` in (needs nix-direnv). First time: `direnv allow`.
# Order matters — later lines override earlier ones.

# 1. Inherit a parent .envrc if there is one — e.g. a company-wide
#    ~/work/acme/.envrc that exports AWS_PROFILE, an internal registry, etc.
#    Safe no-op when there's no parent.
source_up_if_exists

# 2. The reproducible toolchain + non-secret env from flake.nix (mkShell.env).
use flake

# 3. Local, gitignored secrets last so they can override the above:
#    API keys, DATABASE_URL, tokens. Create with:  echo 'API_KEY=…' >> .env
#    Or load from a manager instead, e.g.:
#      export GH_TOKEN="$(pass show acme/gh)"
#      export STRIPE_KEY="$(op read 'op://Acme/stripe/key')"
dotenv_if_exists .env
